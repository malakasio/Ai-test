# ─── JARVIS Configuration ─────────────────────────────────────────────────────
# Copy to .env and fill in your values.
# NOTE: The system runs 100% FREE without any API keys.
#       API keys only improve quality/speed.
# ─── System ───────────────────────────────────────────────────────────────────
JARVIS_HOME=/home/jarvis
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8080
JARVIS_DASHBOARD_PORT=8081
JARVIS_DOMAIN=jarvis.yourdomain.com   # Required for HTTPS
USER_TIMEZONE=Europe/Athens
# Security zones: standard | lab | red
JARVIS_ZONE=standard
JARVIS_LAB_MODE=false    # Set true ONLY in isolated lab environments
# ─── FREE LLM (Ollama — runs locally, no cost) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FAST_MODEL=llama3.2:3b      # Fast, ~0.5s TTFT on CPU
OLLAMA_SMART_MODEL=mistral:7b      # Better quality, slower
OLLAMA_EMBED_MODEL=nomic-embed-text # Free local embeddings
# ─── FREE STT (faster-whisper — runs locally) ─────────────────────────────────
STT_PROVIDER=whisper                # whisper | deepgram
WHISPER_MODEL=base                  # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu                  # cpu | cuda
WHISPER_COMPUTE_TYPE=int8           # int8 | float16
WHISPER_LANGUAGE=el                 # el | en | auto
# ─── FREE TTS (edge-tts — Microsoft online, no key) ───────────────────────────
TTS_PROVIDER=edge                   # edge | kokoro | elevenlabs
EDGE_TTS_VOICE=el-GR-NestorasNeural # Greek male
# EDGE_TTS_VOICE=el-GR-AthinaNeural # Greek female
# KOKORO_VOICE=af_sarah              # If using Kokoro local TTS
# ─── FREE Embeddings (sentence-transformers — runs locally) ───────────────────
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_DIM=384
# ─── OPTIONAL: Telegram Bot (free, no API costs) ──────────────────────────────
# Get token from @BotFather, get your user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
# ─── OPTIONAL: KAIROS daemon ──────────────────────────────────────────────────
KAIROS_ENABLED=true
KAIROS_INTERVAL=300          # seconds between checks (default: 5 min)
KAIROS_GITHUB_REPOS=         # comma-separated: owner/repo,owner/repo2
DREAM_IDLE_THRESHOLD=900     # autoDream after N seconds idle (default: 15 min)
# ─── OPTIONAL PAID: Anthropic Claude API ─────────────────────────────────────
# Uncomment to use Claude API (much faster and smarter than local Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
# ─── OPTIONAL PAID: Deepgram STT (faster, 150-300ms vs 300-500ms) ────────────
# DEEPGRAM_API_KEY=...
# ─── OPTIONAL PAID: ElevenLabs TTS (75ms vs 100-200ms, higher quality) ───────
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel
# ─── OPTIONAL PAID: OpenAI (LLM fallback) ────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ─── Budget controls (for paid APIs) ──────────────────────────────────────────
DAILY_TOKEN_BUDGET=500000    # Max tokens per day before throttling
# ─── Debug ────────────────────────────────────────────────────────────────────
